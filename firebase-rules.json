{
  "rules": {
    "cities": {
      "$cityId": {
        "general": {
          ".read": true,
          ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2"
        },
        "locations": {
          ".read": true,
          "$locationId": {
            ".write": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous' && (root.child('users').child(auth.uid).child('role').val() >= 1 || (newData.exists() && !data.exists() && newData.child('addedBy').val() === auth.uid) || (newData.exists() && data.exists() && data.child('addedBy').val() === auth.uid) || (!newData.exists() && data.child('addedBy').val() === auth.uid))",
            "addedBy": {
              ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() >= 2"
            },
            "locked": {
              ".validate": "newData.val() === false || (newData.val() === true && root.child('users').child(auth.uid).child('role').val() >= 1)"
            },
            "status": {
              ".validate": "newData.val() !== 'blacklist' || root.child('users').child(auth.uid).child('role').val() >= 1"
            }
          }
        },
        "routes": {
          ".read": true,
          "$routeId": {
            ".write": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous' && (root.child('users').child(auth.uid).child('role').val() >= 1 || (newData.exists() && !data.exists() && newData.child('savedBy').val() === auth.uid) || (newData.exists() && data.exists() && data.child('savedBy').val() === auth.uid) || (!newData.exists() && data.child('savedBy').val() === auth.uid))",
            "savedBy": {
              ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() >= 2"
            },
            "savedByName": {
              ".validate": "!newData.exists() || (newData.isString() && !newData.val().contains('@'))"
            }
          }
        },
        "reviews": {
          ".read": true,
          "$placeKey": {
            ".read": true,
            "$userId": {
              ".write": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous' && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() >= 2)",
              ".validate": "newData.hasChildren(['rating', 'timestamp']) || !newData.exists()",
              "userName": {
                ".validate": "!newData.exists() || (newData.isString() && !newData.val().contains('@'))"
              }
            }
          }
        },
        "reviewRatings": {
          ".read": true,
          "$placeKey": {
            ".read": true,
            "$userId": {
              ".write": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous' && (auth.uid === $userId || root.child('users').child(auth.uid).child('role').val() >= 2)",
              ".validate": "newData.isNumber() || !newData.exists()"
            }
          }
        }
      }
    },
    "settings": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2",
      "aboutContent": {
        ".read": true
      },
      "interestGroups": {
        ".read": true
      },
      "interestConfig": {
        ".read": true,
        "$interestId": {
          ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() >= 2 || (root.child('users').child(auth.uid).child('role').val() >= 1 && root.child('customInterests').child($interestId).child('addedBy').val() === auth.uid && root.child('customInterests').child($interestId).child('locked').val() === false))"
        }
      },
      "interestStatus": {
        ".read": true
      },
      "cityHiddenInterests": {
        ".read": true
      },
      "cacheVersion": {
        ".read": true
      }
    },
    "aboutContent": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2"
    },
    "customInterests": {
      ".read": true,
      "$interestId": {
        ".write": "auth != null && (root.child('users').child(auth.uid).child('role').val() >= 2 || (root.child('users').child(auth.uid).child('role').val() >= 1 && ((newData.exists() && !data.exists() && newData.child('addedBy').val() === auth.uid && newData.child('locked').val() === false) || (newData.exists() && data.exists() && data.child('addedBy').val() === auth.uid && data.child('locked').val() === false && newData.child('locked').val() === false) || (!newData.exists() && data.child('addedBy').val() === auth.uid && data.child('locked').val() === false))))",
        "addedBy": {
          ".validate": "!data.exists() || newData.val() === data.val() || root.child('users').child(auth.uid).child('role').val() >= 2"
        },
        "addedByName": {
          ".validate": "!newData.exists() || (newData.isString() && !newData.val().contains('@'))"
        }
      }
    },
    "helpContent": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2"
    },
    "helpAudio": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2"
    },
    "helpAudioDuration": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2"
    },
    "users": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() >= 2)",
        ".write": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() >= 2)",
        "name": {
          ".validate": "newData.isString() && newData.val().length <= 100"
        },
        "email": {
          ".validate": "newData.isString() && newData.val().length <= 200"
        },
        "photo": {
          ".validate": "newData.isString() && newData.val().length <= 500"
        },
        "role": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 2 && (root.child('users').child(auth.uid).child('role').val() >= 2 || (!data.exists() && newData.val() <= 1) || (!data.exists() && newData.val() == 2 && !root.child('users').exists()) || (data.exists() && data.val() == newData.val()))"
        },
        "$other": {
          ".validate": "true"
        }
      }
    },
    "accessStats": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2",
      ".write": "auth != null"
    },
    "feedback": {
      ".read": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2",
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2",
      "$uid": {
        ".read": "auth != null && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() >= 2)",
        ".write": "auth != null && auth.token.firebase.sign_in_provider != 'anonymous' && (auth.uid === $uid || root.child('users').child(auth.uid).child('role').val() >= 2)",
        ".indexOn": ["lastActivityAt"],
        "$entryId": {
          ".validate": "!newData.exists() || newData.hasChildren(['createdAt'])",
          "image": {
            ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 1200000 && (!data.exists() || data.val() === newData.val()))"
          },
          "images": {
            "$idx": {
              ".validate": "$idx.matches(/^[0-2]$/) && (!newData.exists() || (newData.isString() && newData.val().length <= 1200000 && (!data.exists() || data.val() === newData.val())))"
            }
          },
          "messages": {
            "$msgId": {
              ".validate": "!newData.exists() || newData.hasChildren(['from', 'text', 'timestamp'])",
              "from": {
                ".validate": "(newData.val() === 'user' && auth.uid === $uid) || (newData.val() === 'admin' && root.child('users').child(auth.uid).child('role').val() >= 2)"
              },
              "text": {
                ".validate": "newData.isString() && newData.val().length >= 1 && newData.val().length <= 3000"
              },
              "image": {
                ".validate": "!newData.exists() || (newData.isString() && newData.val().length <= 1200000 && (!data.exists() || data.val() === newData.val()))"
              },
              "images": {
                "$idx": {
                  ".validate": "$idx.matches(/^[0-2]$/) && (!newData.exists() || (newData.isString() && newData.val().length <= 1200000 && (!data.exists() || data.val() === newData.val())))"
                }
              }
            }
          }
        }
      }
    },
    "cityStates": {
      ".read": true,
      ".write": "auth != null && root.child('users').child(auth.uid).child('role').val() >= 2"
    },
    "$other": {
      ".read": false,
      ".write": false
    }
  }
}